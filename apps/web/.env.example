# ── Firebase Client SDK ──────────────────────────────────────────────────────
# When using the local emulator, these values are not actually validated,
# so any non-empty strings work for local dev.
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=demo-no-project.firebaseapp.com

# ── API proxy ────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8080

# ── Firebase Auth Emulator (local dev only) ──────────────────────────────────
# Remove (or leave blank) in production.
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
